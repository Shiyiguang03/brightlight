generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             Int             @id @default(autoincrement())
  fullName       String
  email          String?         @unique
  phone          String          @unique
  password       String
  role           String          @default("CUSTOMER")
  profileImage   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  repairRequests RepairRequest[]
}

model RepairRequest {
  id                 Int       @id @default(autoincrement())
  userId             Int
  user               User      @relation(fields: [userId], references: [id])
  deviceType         String
  brand              String
  model              String
  serialNumber       String?
  problemDescription String
  password           String?
  hasCharger         Boolean   @default(false)
  hasPowerCord       Boolean   @default(false)
  hasMouse           Boolean   @default(false)
  hasBag             Boolean   @default(false)
  otherItems         String?
  preferredStartDate DateTime?
  preferredEndDate   DateTime?
  status             String    @default("Pending")
  notes              String?
  images             String[] // ← Removed @default([]) here

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
