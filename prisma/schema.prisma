generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  fullName     String
  email        String?  @unique
  phone        String   @unique
  password     String
  role         String   @default("CUSTOMER")
  profileImage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

 address       String?
  // Requests where this user is the customer
  repairRequests RepairRequest[]

  // Requests submitted by this user (when they are an Agent)
  submittedRepairRequests RepairRequest[] @relation("SubmittedByAgent")
}

model RepairRequest {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id])

  submittedByAgentId Int?
  submittedByAgent   User? @relation("SubmittedByAgent", fields: [submittedByAgentId], references: [id])

  deviceType         String
  brand              String
  model              String
  serialNumber       String?
  problemDescription String
  password           String?
  hasCharger         Boolean   @default(false)
  hasPowerCord       Boolean   @default(false)
  hasMouse           Boolean   @default(false)
  hasBag             Boolean   @default(false)
  otherItems         String?
  preferredStartDate DateTime?
  preferredEndDate   DateTime?
  status             String    @default("Pending")
  urgency            String    @default("Normal")
  internalNotes      String?
  images             String[]  @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

}
